{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "marko",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_node"
      }
    },
    "_node": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "doctype"
        },
        {
          "type": "SYMBOL",
          "name": "scriptlet"
        },
        {
          "type": "SYMBOL",
          "name": "placeholder"
        },
        {
          "type": "SYMBOL",
          "name": "top_level_statement"
        },
        {
          "type": "SYMBOL",
          "name": "element"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "doctype": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<!"
        },
        {
          "type": "PATTERN",
          "value": "[Dd][Oo][Cc][Tt][Yy][Pp][Ee]"
        },
        {
          "type": "PATTERN",
          "value": "[^>]+"
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "top_level_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "static"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "statement_tail"
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "class"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "statement_tail"
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "import"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "statement_tail"
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "export"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "statement_tail"
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        }
      ]
    },
    "statement_tail": {
      "type": "PATTERN",
      "value": "[^\\n]*"
    },
    "element": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "normal_element"
        },
        {
          "type": "SYMBOL",
          "name": "self_closing_element"
        }
      ]
    },
    "normal_element": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_tag"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_node"
          }
        },
        {
          "type": "SYMBOL",
          "name": "end_tag"
        }
      ]
    },
    "self_closing_element": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "_tag_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "tag_default_value"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "attribute"
          }
        },
        {
          "type": "STRING",
          "value": "/>"
        }
      ]
    },
    "start_tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "_tag_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "tag_default_value"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "attribute"
          }
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "end_tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "</"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "_tag_name"
          }
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "_tag_name": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "builtin_tag_name"
        },
        {
          "type": "SYMBOL",
          "name": "flow_tag_name"
        },
        {
          "type": "SYMBOL",
          "name": "function_tag_name"
        },
        {
          "type": "SYMBOL",
          "name": "dynamic_tag_name"
        },
        {
          "type": "SYMBOL",
          "name": "tag_name"
        }
      ]
    },
    "builtin_tag_name": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "script"
        },
        {
          "type": "STRING",
          "value": "style"
        },
        {
          "type": "STRING",
          "value": "html-script"
        },
        {
          "type": "STRING",
          "value": "html-style"
        },
        {
          "type": "STRING",
          "value": "html-comment"
        }
      ]
    },
    "flow_tag_name": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "for"
        },
        {
          "type": "STRING",
          "value": "if"
        },
        {
          "type": "STRING",
          "value": "while"
        },
        {
          "type": "STRING",
          "value": "else-if"
        },
        {
          "type": "STRING",
          "value": "else"
        },
        {
          "type": "STRING",
          "value": "try"
        },
        {
          "type": "STRING",
          "value": "await"
        },
        {
          "type": "STRING",
          "value": "return"
        }
      ]
    },
    "function_tag_name": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "const"
        },
        {
          "type": "STRING",
          "value": "context"
        },
        {
          "type": "STRING",
          "value": "debug"
        },
        {
          "type": "STRING",
          "value": "define"
        },
        {
          "type": "STRING",
          "value": "id"
        },
        {
          "type": "STRING",
          "value": "let"
        },
        {
          "type": "STRING",
          "value": "log"
        },
        {
          "type": "STRING",
          "value": "lifecycle"
        }
      ]
    },
    "dynamic_tag_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "${"
        },
        {
          "type": "SYMBOL",
          "name": "javascript_fragment"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "tag_name": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9_@][A-Za-z0-9_:@.-]*"
    },
    "tag_default_value": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "javascript_fragment"
        }
      ]
    },
    "attribute": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "spread_attribute"
        },
        {
          "type": "SYMBOL",
          "name": "regular_attribute"
        },
        {
          "type": "SYMBOL",
          "name": "shorthand_attribute"
        }
      ]
    },
    "spread_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "..."
        },
        {
          "type": "SYMBOL",
          "name": "javascript_fragment"
        }
      ]
    },
    "shorthand_attribute": {
      "type": "PATTERN",
      "value": "[.#][A-Za-z0-9_$-]+"
    },
    "regular_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "attribute_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "="
                },
                {
                  "type": "FIELD",
                  "name": "value",
                  "content": {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "quoted_attribute_value"
                      },
                      {
                        "type": "SYMBOL",
                        "name": "javascript_fragment"
                      },
                      {
                        "type": "SYMBOL",
                        "name": "unquoted_attribute_value"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "attribute_name": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9_$][A-Za-z0-9_$:-]*"
    },
    "quoted_attribute_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "PATTERN",
                    "value": "[^\"$]+"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "placeholder"
                  }
                ]
              }
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "PATTERN",
                    "value": "[^'$]+"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "placeholder"
                  }
                ]
              }
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        }
      ]
    },
    "unquoted_attribute_value": {
      "type": "PATTERN",
      "value": "[^\\s\"'=<>`]+"
    },
    "scriptlet": {
      "type": "PATTERN",
      "value": "\\$\\s+[^\\n]+"
    },
    "placeholder": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "${"
            },
            {
              "type": "SYMBOL",
              "name": "javascript_fragment"
            },
            {
              "type": "STRING",
              "value": "}"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "$!{"
            },
            {
              "type": "SYMBOL",
              "name": "javascript_fragment"
            },
            {
              "type": "STRING",
              "value": "}"
            }
          ]
        }
      ]
    },
    "javascript_fragment": {
      "type": "PATTERN",
      "value": "[^{}<>\\n\"'`=][^{}<>\\n\"'`=]*"
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^<$\\n][^<$\\n]*"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}